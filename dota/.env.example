# -----------------------------------------------------------------------------
# Local development (copy to .env)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:3000
# Full API origin for Google/Steam/Discord redirects (dev: same as proxy target)
VITE_API_PUBLIC_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Production — Netlify frontend + Hostinger VPS API (bpcleague.in)
# -----------------------------------------------------------------------------
# Set these in Netlify → Site settings → Environment variables before build:
#
# VITE_API_BASE_URL=/api
# VITE_API_PUBLIC_URL=https://api.bpcleague.in
# VITE_SITE_URL=https://bpcleague.in
# VITE_EMERALD_THEME=true
#
# Netlify proxies /api/* to the VPS (see netlify.toml). Keep VITE_API_PUBLIC_URL on
# api.bpcleague.in for OAuth redirects (Google / Discord / Steam).
#
# See docs/deploy-bpcleague.md for the full hosting guide.

# -----------------------------------------------------------------------------
# Social / link previews (Open Graph, Discord, Slack, WhatsApp, etc.)
# -----------------------------------------------------------------------------
# Public site origin — no trailing slash. Required for crawlers that only read raw
# HTML and need an absolute logo URL for embeds:
# VITE_SITE_URL=https://bpcleague.in
