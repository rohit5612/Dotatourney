# -----------------------------------------------------------------------------
# Local development (copy to .env)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:3000

# -----------------------------------------------------------------------------
# Production — Render Static Site + API on AWS EC2
# -----------------------------------------------------------------------------
# Build-time vars for `npm run build`. Point the browser at your EC2 (or ALB) origin.
#
# VITE_API_BASE_URL=https://api.yourdomain.com/api
# Or: http://YOUR_EC2_PUBLIC_IP:3000/api  (use HTTPS in production when possible)

# Proxy is dev-only; omit or leave as-is on Render (not used in production build).
