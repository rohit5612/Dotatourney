# -----------------------------------------------------------------------------
# Local development (copy to .env and edit)
# -----------------------------------------------------------------------------
PORT=3000

# Database: use either DATABASE_URL (recommended on Render Postgres) or discrete vars.
DATABASE_URL=
#
# SSL to Postgres (required for Render when API runs on EC2). Auto-on for non-localhost URLs.
# DATABASE_SSL=false   # e.g. local Docker hostname "db" without TLS
# DATABASE_SSL=true    # force TLS even for odd hostnames
# DATABASE_SSL_REJECT_UNAUTHORIZED=true   # optional stricter cert check (default: do not require CA match; see node-pg + Render docs)
#
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=dota
# DB_USER=postgres
# DB_PASSWORD=

# Comma-separated allowed browser origins for CORS (no trailing slashes).
# Local:
CORS_ORIGIN=http://localhost:5173
# Production: your Render static site URL(s), no trailing slash. Example:
# CORS_ORIGIN=https://dotatourney.onrender.com
# Multiple sites: comma-separated (e.g. staging + prod).

# Public URL of the frontend — used in admin invite emails (same as primary CORS origin).
APP_URL=http://localhost:5173
# Production (match the site users open in the browser):
# APP_URL=https://dotatourney.onrender.com

# -----------------------------------------------------------------------------
# Production layout (bpcleague.in — see docs/deploy-bpcleague.md)
# -----------------------------------------------------------------------------
# Frontend: Netlify at https://bpcleague.in
# API: Hostinger VPS at https://api.bpcleague.in
# Postgres: localhost on VPS
# Redis: Upstash free tier (UPSTASH_REDIS_REST_URL + TOKEN)

# NODE_ENV=production
# CORS_ORIGIN=https://bpcleague.in,https://www.bpcleague.in
# APP_URL=https://bpcleague.in
# API_PUBLIC_URL=https://api.bpcleague.in

# Invite links expire after this many hours (default 4).
ADMIN_INVITE_EXPIRY_HOURS=4

# Secret for hashing player registration OTPs (any long random string in production).
# REGISTRATION_OTP_SECRET=

# Player accounts (Season 2 Phase 1+)
# PLAYER_TOKEN_SECRET=   # sessions, email verify, OAuth state (defaults to REGISTRATION_OTP_SECRET)
# API_PUBLIC_URL=http://localhost:3000
# Production (OAuth callbacks hit the API): API_PUBLIC_URL=https://api.bpcleague.in
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# STEAM_API_KEY=

# Cashfree Payment Gateway (Season 2 Phase 3+)
# CASHFREE_CLIENT_ID=
# CASHFREE_CLIENT_SECRET=
# CASHFREE_ENV=sandbox
# Production: CASHFREE_ENV=production
# Webhook URL: https://api.yourdomain.com/api/webhooks/cashfree

# -----------------------------------------------------------------------------
# Email (SMTP via Nodemailer) — deliverability
# -----------------------------------------------------------------------------
# In production, avoid spam folder by:
# - Publishing SPF + DKIM + DMARC for the DOMAIN you send as (see docs/email.md).
# - Setting EMAIL_FROM to that domain (e.g. "BPC League <noreply@yourdomain.com>").
# - Prefer a transactional provider (Resend, Postmark, SES, etc.) over free Gmail SMTP.
#
# Optional: monitored inbox for replies (leaves From as noreply if you use that).
# EMAIL_REPLY_TO=support@yourdomain.com

# --- Example A: Gmail / Google Workspace (App Password or Workspace SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=your-account@gmail.com
EMAIL_PASS=your-16-char-app-password
# Display name + address; should match the mailbox or your verified Workspace domain:
EMAIL_FROM="BPC League" <your-account@gmail.com>
EMAIL_SUBJECT_PREFIX=[BPC League | Bharat Pro Circuit League]

# --- Example B: Resend (SMTP) — verify domain + DNS in Resend dashboard ---
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# EMAIL_USER=resend
# EMAIL_PASS=re_xxxxxxxx   # API key as SMTP password
# EMAIL_FROM="BPC League" <noreply@yourverifieddomain.com>

# --- Example C: Postmark (SMTP) —
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USER=your-server-token
# EMAIL_PASS=your-server-token
# EMAIL_FROM="BPC League" <approved-sender@yourverifieddomain.com>

# Local-only: skip sending mail but still create invites (returns link in API).
# Do not set this in production.
# EMAIL_SKIP_SEND=true

# -----------------------------------------------------------------------------
# Google Sheets (on-demand sync from admin). Enable Google Sheets API + service account in GCP.
# Share the target spreadsheet with the service account email as Editor.
# Pick ONE: inline JSON, base64 JSON, or path to the key file.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=
# GOOGLE_APPLICATION_CREDENTIALS=./secrets-google-sa.json

# -----------------------------------------------------------------------------
# Public read cache (Redis / Upstash)
# -----------------------------------------------------------------------------
# Local development — standard Redis URL:
# REDIS_URL=redis://localhost:6379
#
# Production (Upstash) — either Redis URL from the Upstash dashboard:
# REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379
# …or REST credentials (preferred on serverless; also works on VPS):
# UPSTASH_REDIS_REST_URL=https://YOUR_HOST.upstash.io
# UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN
#
# Optional TTL overrides (milliseconds):
# PUBLIC_CACHE_L1_TTL_MS=8000
# PUBLIC_CACHE_REDIS_TTL_MS=45000
#
# Hosted holo portrait GIFs (saved to dota/public/cards/gifs in dev; served at /cards/gifs).
# PORTRAIT_GIF_DIR=../dota/public/cards/gifs
# PORTRAIT_GIF_URL_BASE=https://api.bpcleague.in/cards/gifs
#
# Season detail payloads are cached under the same Redis layer (public:v*:seasons:slug:*).
# Active seasons benefit most — ensure REDIS_URL or Upstash REST vars are set in production.
#
# Claim-account test seed (3 fresh legacy S1 players after highest BPC-### in DB):
#   node scripts/seed-s1-claimable-players.js --apply
# Optional real emails: CLAIM_S1_EMAILS=one@x.com,two@y.com,three@z.com node scripts/seed-s1-claimable-players.js --apply
