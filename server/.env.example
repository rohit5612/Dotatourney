# -----------------------------------------------------------------------------
# Local development (copy to .env and edit)
# -----------------------------------------------------------------------------
PORT=3000

# Database: use either DATABASE_URL (recommended on Render Postgres) or discrete vars.
DATABASE_URL=
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=dota
# DB_USER=postgres
# DB_PASSWORD=

# Comma-separated allowed browser origins for CORS (no trailing slashes).
# Local:
CORS_ORIGIN=http://localhost:5173
# Production: your Render static site URL(s), e.g.
# CORS_ORIGIN=https://your-app.onrender.com

# Public URL of the frontend — used in admin invite emails (same as primary CORS origin).
APP_URL=http://localhost:5173
# Production:
# APP_URL=https://your-app.onrender.com

# -----------------------------------------------------------------------------
# Production layout (example)
# -----------------------------------------------------------------------------
# - Postgres: Render (set DATABASE_URL from the Render dashboard)
# - Frontend: Render static site → APP_URL + CORS_ORIGIN = that site URL
# - API: AWS EC2 (set NODE_ENV=production, PORT, DATABASE_URL, APP_URL, CORS_ORIGIN, SMTP below)

# NODE_ENV=production

# Invite links expire after this many hours (default 4).
ADMIN_INVITE_EXPIRY_HOURS=4

# Gmail: use an App Password (Google Account → Security → 2FA → App passwords).
# Never commit real credentials; set these in EC2 env / secrets manager only.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=your-account@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=your-account@gmail.com
EMAIL_SUBJECT_PREFIX=[The Forge | Dota 2 Cup]

# Local-only: skip sending mail but still create invites (returns link in API).
# Do not set this in production.
# EMAIL_SKIP_SEND=true
